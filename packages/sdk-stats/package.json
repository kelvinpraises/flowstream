{
  "name": "@flowstream/sdk-stats",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && npm run copy-assets",
    "copy-assets": "shx mkdir -p dist/content/football && shx cp -r src/content/football/cv dist/content/football/",
    "dev": "tsc --watch",
    "test": "vitest run --exclude test/e2e.test.ts",
    "test:e2e": "vitest run test/e2e.test.ts --testTimeout=0",
    "test:watch": "vitest --exclude test/e2e.test.ts"
  },
  "dependencies": {
    "@flowstream/types": "workspace:*",
    "gl": "^8.1.6",
    "puppeteer": "^25.0.4",
    "three": "^0.124.0"
  },
  "devDependencies": {
    "@types/gl": "^6.0.5",
    "shx": "^0.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
